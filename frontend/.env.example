# ==============================================================
# GovFlow Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
#
#   cp frontend/.env.example frontend/.env.local
#
# All NEXT_PUBLIC_* variables are embedded in the client bundle.
# Do NOT put secrets in NEXT_PUBLIC_* variables.
# ==============================================================

# --------------------------------------------------------------
# API Connection  [REQUIRED]
# --------------------------------------------------------------

# [REQUIRED] Base URL of the GovFlow FastAPI backend.
# Local dev: http://localhost:8100
# Production: https://api.govflow.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8100

# [REQUIRED] WebSocket URL of the GovFlow backend.
# Local dev: ws://localhost:8100
# Production: wss://api.govflow.yourdomain.com
NEXT_PUBLIC_WS_URL=ws://localhost:8100

# --------------------------------------------------------------
# Site
# --------------------------------------------------------------

# [OPTIONAL] Public site URL (used for SEO canonical URLs + OG tags).
# Local dev: http://localhost:3100
# Production: https://govflow.yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# [OPTIONAL] Environment name for client-side logic.
# Values: local | staging | production
NEXT_PUBLIC_ENV=local

# --------------------------------------------------------------
# Observability
# --------------------------------------------------------------

# [OPTIONAL — PROD RECOMMENDED] Sentry DSN for frontend error tracking.
# Get from https://sentry.io — create a Next.js project.
# Format: https://xxx@oXX.ingest.sentry.io/yyy
NEXT_PUBLIC_SENTRY_DSN=
