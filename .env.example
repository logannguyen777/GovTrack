# ============================================================
# GovFlow Environment Configuration
# Copy to .env and fill in values
# ============================================================

# --- Environment mode ---
GOVFLOW_ENV=local          # local | cloud

# --- GDB (Gremlin) ---
GDB_ENDPOINT=ws://localhost:8182/gremlin
GDB_USERNAME=
GDB_PASSWORD=

# --- Hologres / PostgreSQL ---
HOLOGRES_DSN=postgresql://govflow:govflow_dev_2026@localhost:5433/govflow

# --- DashScope (Qwen AI) ---
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- OSS / MinIO ---
OSS_ENDPOINT=http://localhost:9100
OSS_ACCESS_KEY_ID=minioadmin
OSS_ACCESS_KEY_SECRET=minioadmin123
OSS_BUCKET=govflow-dev
OSS_REGION=us-east-1

# --- JWT ---
JWT_SECRET=dev-secret-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- CORS ---
CORS_ORIGINS=http://localhost:3100

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_SEARCH=30/minute

# --- Logging ---
LOG_LEVEL=DEBUG

# --- Qwen model routing (override defaults if needed) ---
# QWEN_REASONING=qwen-plus-latest
# QWEN_REASONING_MAX=qwen-max-latest
# QWEN_REASONING_LITE=qwen-turbo-latest
# QWEN_VISION=qwen-vl-plus-latest
# QWEN_VISION_MAX=qwen-vl-max-latest

# --- Frontend (Next.js) ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SITE_URL=https://govflow.vn
NEXT_PUBLIC_WS_URL=ws://localhost:8100/api/ws
