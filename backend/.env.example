# ==============================================================
# GovFlow Backend — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp backend/.env.example backend/.env
#
# Variables marked [REQUIRED] must be set before the app starts.
# Variables marked [OPTIONAL] have safe defaults for local dev.
# Variables marked [PROD REQUIRED] are required in cloud mode.
# ==============================================================

# --------------------------------------------------------------
# General
# --------------------------------------------------------------

# [OPTIONAL] Environment name. Values: local | cloud
# Set to "cloud" in production — triggers strict JWT validation,
# removes localhost from OSS allowlist, and enforces strong secrets.
GOVFLOW_ENV=local

# [OPTIONAL] Log verbosity. Values: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# --------------------------------------------------------------
# DashScope / Qwen3 AI Models  [REQUIRED for agent functionality]
# --------------------------------------------------------------

# [REQUIRED] Alibaba Cloud Model Studio API key.
# Get a free trial key at: https://bailian.console.aliyun.com/
# Format: sk-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_API_KEY=

# [OPTIONAL] DashScope API base URL.
# Use the international endpoint for servers outside mainland China.
# Mainland China: https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# [OPTIONAL] Per-user daily DashScope token budget.
# Prevents runaway LLM costs per user account.
# Default: 100000 tokens/user/day
DASHSCOPE_TOKENS_PER_USER_PER_DAY=100000

# --------------------------------------------------------------
# JWT Authentication
# --------------------------------------------------------------

# [PROD REQUIRED] Secret key for HS256 JWT signing.
# Must be >= 32 characters in cloud mode.
# Generate with: openssl rand -hex 32
# WARNING: The default value below is INSECURE. Change it.
JWT_SECRET=dev-secret-change-in-production-2026

# [OPTIONAL] JWT algorithm. Default: HS256
JWT_ALGORITHM=HS256

# [OPTIONAL] JWT access token expiry in minutes. Default: 480 (8 hours)
JWT_EXPIRE_MINUTES=480

# --------------------------------------------------------------
# Graph Database (Alibaba Cloud GDB / TinkerPop Gremlin)
# Local dev: uses TinkerGraph via Docker (see infra/docker-compose.yml)
# Production: Alibaba Cloud GDB instance
# --------------------------------------------------------------

# [OPTIONAL for local] GDB WebSocket endpoint.
# Local (docker): ws://localhost:8182/gremlin
# Alibaba Cloud GDB: wss://your-gdb-instance.gdb.aliyuncs.com:8182/gremlin
GDB_ENDPOINT=ws://localhost:8182/gremlin

# [OPTIONAL for local] GDB credentials (empty = no auth for local TinkerGraph)
GDB_USERNAME=
GDB_PASSWORD=

# --------------------------------------------------------------
# Hologres / PostgreSQL (analytics, users, law embeddings)
# Local dev: uses PostgreSQL 16 + pgvector via Docker
# Production: Alibaba Cloud Hologres instance
# --------------------------------------------------------------

# [OPTIONAL for local] PostgreSQL connection string.
# Local: postgresql://govflow:govflow_dev_2026@localhost:5433/govflow
# Alibaba Cloud Hologres: postgresql://user:pass@hologres-instance:80/govflow
HOLOGRES_DSN=postgresql://govflow:govflow_dev_2026@localhost:5433/govflow

# --------------------------------------------------------------
# OSS / Object Storage (documents, templates, archives)
# Local dev: uses MinIO via Docker
# Production: Alibaba Cloud OSS
# --------------------------------------------------------------

# [OPTIONAL for local] OSS / MinIO endpoint.
# Local (MinIO): http://localhost:9100
# Alibaba Cloud OSS: https://oss-ap-southeast-1.aliyuncs.com
OSS_ENDPOINT=http://localhost:9100

# [REQUIRED] OSS access credentials.
# Local: minioadmin / minioadmin123 (from docker-compose.yml)
# Production: RAM user Access Key with OSS read/write permissions
OSS_ACCESS_KEY_ID=minioadmin
OSS_ACCESS_KEY_SECRET=minioadmin123

# [OPTIONAL] OSS bucket name. Default: govflow-dev
OSS_BUCKET=govflow-dev

# [OPTIONAL] OSS region. Default: us-east-1 (MinIO default)
# Alibaba Cloud: oss-ap-southeast-1
OSS_REGION=us-east-1

# [OPTIONAL — PROD RECOMMENDED] STS Role ARN for short-lived OSS credentials.
# Enables STS token rotation instead of long-lived Access Keys.
# Get from Alibaba Cloud RAM: acs:ram::your-account-id:role/govflow-oss-role
# OSS_STS_ROLE_ARN=acs:ram::123456789:role/govflow-oss-role
OSS_STS_ROLE_ARN=

# [OPTIONAL — PROD RECOMMENDED] KMS Key ID for OSS server-side encryption (SSE-KMS).
# Get from Alibaba Cloud KMS: alias/govflow-oss-key or full key ARN
# OSS_KMS_KEY_ID=alias/govflow-oss-key
OSS_KMS_KEY_ID=

# [OPTIONAL] Pre-signed URL TTL for GET requests (seconds). Default: 300 (5 min)
OSS_PRESIGN_GET_TTL_S=300

# [OPTIONAL] Pre-signed URL TTL for PUT requests (seconds). Default: 3600 (1 hour)
OSS_PRESIGN_PUT_TTL_S=3600

# --------------------------------------------------------------
# CORS
# --------------------------------------------------------------

# [OPTIONAL] Comma-separated list of allowed CORS origins.
# Local: http://localhost:3100
# Production: https://govflow.yourdomain.com
CORS_ORIGINS=http://localhost:3100

# --------------------------------------------------------------
# Rate Limiting
# --------------------------------------------------------------

# [OPTIONAL] Default rate limit for all endpoints.
RATE_LIMIT_DEFAULT=60/minute

# [OPTIONAL] Rate limit for search endpoints.
RATE_LIMIT_SEARCH=30/minute

# [OPTIONAL] Redis URL for distributed rate limiting.
# Required in multi-instance production deployments.
# Format: redis://user:pass@host:6379/0
# Omit for single-instance deployments (in-memory fallback).
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# --------------------------------------------------------------
# Observability
# --------------------------------------------------------------

# [OPTIONAL — PROD RECOMMENDED] OpenTelemetry OTLP endpoint.
# Sends traces to Jaeger / Grafana Tempo / Alibaba Cloud SLS.
# Format: http://otel-collector:4317
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# [OPTIONAL — PROD RECOMMENDED] Sentry DSN for error tracking.
# Get from https://sentry.io — create a Python/FastAPI project.
# Format: https://xxx@oXX.ingest.sentry.io/yyy
# SENTRY_DSN=https://xxx@oXX.ingest.sentry.io/yyy
SENTRY_DSN=

# [OPTIONAL] Comma-separated IPs allowed to scrape /metrics (Prometheus).
# Empty string = allow all (default for local dev).
# Production: set to your Prometheus server IP.
# PROMETHEUS_ALLOW_IPS=10.0.0.5
PROMETHEUS_ALLOW_IPS=

# --------------------------------------------------------------
# Upload Limits
# --------------------------------------------------------------

# [OPTIONAL] Max upload size for regular users (MB). Default: 20
MAX_UPLOAD_MB_DEFAULT=20

# [OPTIONAL] Max upload size for privileged users (MB). Default: 50
MAX_UPLOAD_MB_PRIVILEGED=50

# --------------------------------------------------------------
# Qwen Task Timeouts
# --------------------------------------------------------------

# [OPTIONAL] Timeout for Qwen3-VL vision tasks (seconds). Default: 180
QWEN_TIMEOUT_VISION_S=180

# [OPTIONAL] Timeout for Qwen3-Max reasoning tasks (seconds). Default: 120
QWEN_TIMEOUT_REASONING_S=120

# [OPTIONAL] Timeout for Qwen3-Embedding tasks (seconds). Default: 30
QWEN_TIMEOUT_EMBEDDING_S=30

# --------------------------------------------------------------
# Chat / Assistant
# --------------------------------------------------------------

# [OPTIONAL] Chat rate limit per minute per session. Default: 20
CHAT_RATE_LIMIT_PER_MINUTE=20

# [OPTIONAL] Chat session TTL in hours. Default: 24
CHAT_SESSION_TTL_HOURS=24

# [OPTIONAL] Max assistant tool call iterations per turn. Default: 4
ASSISTANT_MAX_TOOL_ITERATIONS=4

# [OPTIONAL] Max assistant chat history messages to keep. Default: 20
ASSISTANT_HISTORY_LIMIT=20

# --------------------------------------------------------------
# OSS SSRF Protection
# --------------------------------------------------------------

# [OPTIONAL] Comma-separated domain allowlist for OSS URLs.
# Only URLs matching these domains are accepted as file_url inputs.
# In cloud mode, 'localhost' is automatically removed from this list.
OSS_ALLOWED_DOMAINS=aliyuncs.com,oss-cn-,oss-ap-,localhost

# --------------------------------------------------------------
# Demo Mode  (set automatically by start_demo.sh — do not edit)
# --------------------------------------------------------------

# [OPTIONAL] Enable demo mode (cached LLM responses, relaxed rate limits).
DEMO_MODE=false

# [OPTIONAL] Enable LLM response caching for demo.
DEMO_CACHE_ENABLED=false

# [OPTIONAL] Directory for cached LLM responses.
DEMO_CACHE_DIR=.cache/llm_responses

# [OPTIONAL] If true, fail immediately on cache miss (pure offline demo mode).
DEMO_CACHE_OFFLINE_ONLY=false

# [OPTIONAL] Rate limit for demo users (relaxed for live demo).
DEMO_USER_RATE_LIMIT=1000/minute

# [OPTIONAL] Agent pipeline timeout in demo mode (seconds). Default: 60
DEMO_TIMEOUT_SECONDS=60
